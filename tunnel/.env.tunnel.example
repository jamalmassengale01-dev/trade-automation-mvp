# ============================================
# Cloudflare Tunnel Environment Variables
# Copy this file to .env.tunnel and fill in your values
# ============================================

# Required: Your Cloudflare Tunnel token
# Get this by running: cloudflared tunnel token <TUNNEL_ID>
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here

# Optional: Your public domain
# This is just for reference in the app
TUNNEL_URL=https://trading-api.yourdomain.com

# ============================================
# Local Development Database & Redis
# These use host.docker.internal to connect to your local services
# ============================================

# Option 1: Use local PostgreSQL (if running natively)
DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:5432/trade_automation

# Option 2: Use Docker PostgreSQL (if using docker-compose.yml)
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/trade_automation

# Option 1: Use local Redis (if running natively)
REDIS_URL=redis://host.docker.internal:6379

# Option 2: Use Docker Redis (if using docker-compose.yml)
# REDIS_URL=redis://redis:6379

# ============================================
# Webhook & App Settings
# ============================================

# Webhook secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
WEBHOOK_SECRET=dev-secret-change-me

# Feature flags
ENABLE_MOCK_BROKER=true
ENABLE_SIMULATED_BROKER=true

# Logging
LOG_LEVEL=debug
