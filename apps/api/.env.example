# ============================================
# SERVER CONFIG
# ============================================
NODE_ENV=development
PORT=3001
API_HOST=0.0.0.0

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trade_automation

# ============================================
# REDIS (for BullMQ)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# WEBHOOK SECURITY
# ============================================
WEBHOOK_SECRET=your-secret-key-here-change-in-production

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_MOCK_BROKER=true
ENABLE_SIMULATED_BROKER=true
GLOBAL_KILL_SWITCH=false
