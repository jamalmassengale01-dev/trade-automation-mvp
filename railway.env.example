# ============================================
# Railway Deployment Environment Variables
# Copy this to Railway dashboard → Variables
# ============================================

# Required: Database connection (Supabase or Railway Postgres)
DATABASE_URL=postgresql://postgres:password@host:5432/database

# Required: Redis connection (Upstash or Railway Redis)
REDIS_URL=redis://default:password@host:6379

# Required: Webhook security (generate strong random string)
WEBHOOK_SECRET=change-this-to-a-random-string-min-32-chars

# Optional: Server configuration
PORT=3001
NODE_ENV=production

# Optional: Logging
LOG_LEVEL=info

# Optional: Feature flags
ENABLE_MOCK_BROKER=true
ENABLE_SIMULATED_BROKER=true
GLOBAL_KILL_SWITCH=false
